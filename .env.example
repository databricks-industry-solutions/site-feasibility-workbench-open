# Copy this file to .env and fill in your values for local development.
# In production (Databricks Apps), set these via the env: block in app.yaml instead.

# ── Required ──────────────────────────────────────────────────────────────────

# Your SQL Warehouse ID (find in SQL > SQL Warehouses)
DATABRICKS_WAREHOUSE_ID=

# Unity Catalog name where your seed tables live (set in notebooks/00_seed_data.py)
UC_CATALOG=

# ── Optional ──────────────────────────────────────────────────────────────────

# AI/BI Genie Space ID — run notebooks/01_create_genie_space.py to generate this
# GENIE_SPACE_ID=

# Override the RWE claims table location.
# Defaults to: <UC_CATALOG>.dbx_marketplace_rwe_synthetic.claims_sample_synthetic
# RWE_CLAIMS_TABLE=

# Databricks CLI profile to use for local dev (default: DEFAULT)
# DATABRICKS_PROFILE=DEFAULT

# ── Lakebase (auto-injected by Databricks Apps in production) ─────────────────
# For local dev, leave these commented out unless you have a local Lakebase connection.
# PGHOST=
# PGPORT=5432
# PGDATABASE=databricks_postgres
# PGUSER=
# PGPASSWORD=
