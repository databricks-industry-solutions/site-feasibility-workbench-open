# Copy this file to .env and fill in your values for local development.
# In production (Databricks Apps), set these via app.yaml env: block.

# Required: your SQL Warehouse ID
DATABRICKS_WAREHOUSE_ID=

# Required: your AI/BI Genie space ID
GENIE_SPACE_ID=

# Required: Unity Catalog catalog name where your data lives
UC_CATALOG=siebenlist

# Optional: override HealthVerity table (defaults to samples.healthverity.claims_sample_synthetic)
# HEALTHVERITY_TABLE=

# Optional: Databricks CLI profile to use for local dev (default: DEFAULT)
# DATABRICKS_PROFILE=DEFAULT

# Optional: Lakebase connection (auto-injected by Databricks Apps resources block in production)
# PGHOST=
# PGPORT=5432
# PGDATABASE=databricks_postgres
# PGUSER=
# PGPASSWORD=
